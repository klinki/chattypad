{
  "name": "chattypad",
  "version": "0.0.1",
  "description": "Desktop chat workspace application",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "electrobun dev",
    "start:debug": "set CHATTYPAD_DEBUG=1&& electrobun dev",
    "dev": "electrobun dev --watch",
    "build": "electrobun build",
    "build:renderer": "node scripts/build-renderer.mjs",
    "test": "bun test",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "electrobun": "^1.15.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.4.5"
  }
}
